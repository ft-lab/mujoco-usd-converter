<mujoco model="collision_filtering">
  <worldbody>
    <geom name="floor" type="plane" size="1 1 0.1"
        contype="1" conaffinity="2"
        rgba="0.8 0.9 0.8 1"/>

    <!-- box_body_default and sphere_body_default collide with the floor and with each other. -->
    <body name="box_body_default" pos="-0.3 0 0.3">
        <freejoint/>
        <geom name="box_geom_default" type="box" size="0.08 0.08 0.05"
            contype="1" conaffinity="1"
            rgba="0.0 1.0 0.0 1"/>
    </body>
    <body name="sphere_body_default" pos="-0.3 0 0.8">
        <freejoint/>
        <geom name="sphere_geom_default" type="sphere" size="0.1"
            contype="1" conaffinity="1"
            rgba="1.0 0.0 0.0 1"/>
    </body>

    <!-- box_body and sphere_body collide with the floor but do not collide with each other -->
    <body name="box_body" pos="0 0 0.3">
        <freejoint/>
        <geom name="box_geom" type="box" size="0.08 0.08 0.05"
            contype="2" conaffinity="1"
            rgba="0.0 1.0 0.0 1"/>
    </body>
    <body name="sphere_body" pos="0 0 0.8">
        <freejoint/>
        <geom name="sphere_geom" type="sphere" size="0.1"
            contype="2" conaffinity="1"
            rgba="1.0 0.0 0.0 1"/>
    </body>
  </worldbody>
</mujoco>
